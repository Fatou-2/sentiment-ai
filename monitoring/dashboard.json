{
  "title": "SentimentAI",
  "panels": [
    {
      "title": "Requêtes/s",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "rate(http_requests_total{handler=\"/predict\"}[1m])", "datasource": {"type": "prometheus"}}]
    },
    {
      "title": "Latence p99",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.99, rate(sentiment_prediction_duration_seconds_bucket[5m]))", "datasource": {"type": "prometheus"}}]
    },
    {
      "title": "Taux erreurs",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{"expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m]) * 100", "datasource": {"type": "prometheus"}}]
    },
    {
      "title": "Confiance",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "avg(sentiment_confidence_score)", "datasource": {"type": "prometheus"}}]
    }
  ],
  "schemaVersion": 36,
  "version": 1
}
